[
  {
    "id": "TC001",
    "title": "Successful sign up redirects to Account overview",
    "description": "Verifies a new user can register with valid details and is redirected to the account overview page.",
    "category": "User Authentication (Sign Up)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /register"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Sign Up\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Test User\" into the name field"
      },
      {
        "type": "action",
        "description": "Type \"testsprite.user+signup1@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"Str0ngPass!234\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign Up\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/account\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Account\" is visible"
      }
    ]
  },
  {
    "id": "TC002",
