[
  {
    "id": "TC001",
    "title": "Successful login redirects user to Account dashboard",
    "description": "Verifies that a user can sign in with valid email and password and is redirected to the account dashboard.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/account\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Account\" is visible"
      }
    ]
  },
