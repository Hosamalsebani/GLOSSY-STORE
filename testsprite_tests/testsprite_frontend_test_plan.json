    "steps": [
      {
        "type": "action",
        "description": "Navigate to /register"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Sign Up\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Weak Password\" into the name field"
      },
      {
        "type": "action",
        "description": "Type \"testsprite.user+weakpass@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"12345\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign Up\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"password\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/register\""
      }
    ]
  },
