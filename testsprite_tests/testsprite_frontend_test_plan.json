  {
    "id": "TC005",
    "title": "Save privacy settings successfully and see confirmation",
    "description": "Verifies an authenticated user can change privacy preferences and successfully save them with a visible confirmation.",
    "category": "Account Settings (Privacy Settings)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/account\""
      },
      {
        "type": "action",
        "description": "Click on \"Privacy settings\""
      },
      {
        "type": "action",
        "description": "Toggle the cookies preference"
      },
      {
        "type": "action",
        "description": "Click \"Save settings\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Settings saved\" is visible"
      }
    ]
  },
  {
    "id": "TC006",
    "title": "Privacy settings persist after saving and revisiting privacy settings",
    "description": "Verifies that saved privacy preferences remain updated when the user reopens the privacy settings.",
    "category": "Account Settings (Privacy Settings)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/account\""
      },
      {
        "type": "action",
        "description": "Click on \"Privacy settings\""
      },
      {
        "type": "action",
        "description": "Toggle the tracking preference"
      },
      {
        "type": "action",
        "description": "Click \"Save settings\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Settings saved\" is visible"
      },
      {
        "type": "action",
        "description": "Click on \"Account\" or \"Back\" to return to the account overview"
      },
      {
        "type": "action",
        "description": "Click on \"Privacy settings\" again"
      },
      {
        "type": "assertion",
        "description": "Verify the tracking preference toggle shows the updated state"
      }
    ]
  },
